{
    "name": "@spirex/config-provider-ini",
    "version": "1.0.0",
    "description": "INI file provider for @spirex/config — loads INI files into layered configuration with file watching support",
    "keywords": [
        "config",
        "configuration",
        "ini",
        "file",
        "provider",
        "watch",
        "settings",
        "section",
        "layered",
        "multi-provider",
        "spirex"
    ],
    "license": "MIT",
    "private": false,
    "sideEffects": false,
    "author": {
        "name": "Artem Sobolenkov (SpireX)",
        "email": "SpireX@outlook.com",
        "url": "https://github.com/SpireX64"
    },
    "homepage": "https://github.com/SpireX64/spirex-config",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SpireX64/spirex-config.git"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "default": "./dist/index.mjs"
            },
            "require": {
                "default": "./dist/index.cjs"
            },
            "default": {
                "default": "./dist/index.js"
            }
        },
        "./ini-reader": {
            "import": {
                "default": "./dist/ini-reader.mjs"
            },
            "require": {
                "default": "./dist/ini-reader.cjs"
            },
            "default": {
                "default": "./dist/ini-reader.js"
            }
        }
    },
    "scripts": {
        "prepack": "yarn build:release && cp ../../LICENSE ./LICENSE",
        "test": "vitest run --config ./vitest.config.mjs",
        "test:c": "vitest run --config ./vitest.config.mjs --coverage",
        "build": "rollup --config --environment NODE_ENV:development",
        "build:release": "rollup --config --environment NODE_ENV:production",
        "clean": "rimraf dist coverage"
    },
    "peerDependencies": {
        "@spirex/config": "^1"
    },
    "devDependencies": {
        "@spirex/config": "workspace:*"
    }
}