{
    "name": "@spirex/config-provider-env",
    "version": "1.0.0",
    "description": "Environment variable provider for @spirex/config — maps process.env into layered configuration",
    "keywords": [
        "config",
        "configuration",
        "env",
        "environment",
        "provider",
        "environment-variables",
        "process.env",
        "settings",
        "prefix",
        "section",
        "layered",
        "multi-provider",
        "spirex"
    ],
    "license": "MIT",
    "private": false,
    "sideEffects": false,
    "author": {
        "name": "Artem Sobolenkov (SpireX)",
        "email": "SpireX@outlook.com",
        "url": "https://github.com/SpireX64"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "default": "./dist/index.mjs"
            },
            "require": {
                "default": "./dist/index.cjs"
            },
            "default": {
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "prepack": "yarn build:release && cp ../../LICENSE ./LICENSE",
        "test": "vitest run --config ./vitest.config.mjs",
        "test:c": "vitest run --config ./vitest.config.mjs --coverage",
        "build": "rollup --config --environment NODE_ENV:development",
        "build:release": "rollup --config --environment NODE_ENV:production",
        "clean": "rimraf dist coverage"
    },
    "peerDependencies": {
        "@spirex/config": "^1"
    },
    "devDependencies": {
        "@spirex/config": "workspace:*"
    }
}