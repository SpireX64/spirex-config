{
    "name": "@spirex/config",
    "version": "1.0.0",
    "description": "Composable, priority-based configuration with typed access, section scoping, lazy fallbacks, and hot reload — combine multiple providers for layered app settings.",
    "keywords": [
        "config",
        "configuration",
        "env",
        "settings",
        "layered",
        "builder",
        "typed",
        "scoped",
        "reload",
        "fallback",
        "multi-provider",
        "spirex"
    ],
    "license": "MIT",
    "private": false,
    "sideEffects": false,
    "author": {
        "name": "Artem Sobolenkov (SpireX)",
        "email": "SpireX@outlook.com",
        "url": "https://github.com/SpireX64"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "default": "./dist/index.mjs"
            },
            "require": {
                "default": "./dist/index.cjs"
            },
            "default": {
                "default": "./dist/index.js"
            }
        },
        "./in-memory": {
            "import": {
                "default": "./dist/in-memory.mjs"
            },
            "require": {
                "default": "./dist/in-memory.cjs"
            },
            "default": {
                "default": "./dist/in-memory.js"
            }
        }
    },
    "scripts": {
        "prepack": "yarn build:release && cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE",
        "test": "vitest run --config ./vitest.config.mjs",
        "test:c": "vitest run --config ./vitest.config.mjs --coverage",
        "build": "rollup --config --environment NODE_ENV:development",
        "build:release": "rollup --config --environment NODE_ENV:production",
        "clean": "rimraf dist coverage"
    }
}